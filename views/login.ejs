<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Student Management System</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Inter',sans-serif;
        }

        body{
            background:#F4F7FE;
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            padding:20px;
        }

        .login-card{
            width:100%;
            max-width:420px;
            background:#fff;
            padding:50px 40px;
            border-radius:24px;
            box-shadow:0 20px 45px rgba(15,23,42,.08);
        }

        .logo-box{
            width:50px;
            height:50px;
            margin:0 auto 18px;
            border-radius:12px;
            background:linear-gradient(135deg,#FF9C00,#FFC048);
            color:#fff;
            font-size:24px;
            font-weight:700;
            display:flex;
            align-items:center;
            justify-content:center;
        }

        h2{
            color:#2B3674;
            font-weight:700;
            text-align:center;
            margin-bottom:8px;
        }

        .subtitle{
            text-align:center;
            color:#A3AED0;
            margin-bottom:30px;
            font-size:15px;
        }

        .form-label{
            font-weight:600;
            color:#2B3674;
            margin-bottom:8px;
        }

        .form-control{
            height:52px;
            border:none;
            border-radius:12px;
            background:#F8FAFC;
            padding:0 16px;
            transition:.3s;
        }

        .form-control:focus{
            background:#fff;
            border:2px solid #6366F1;
            box-shadow:none;
        }

        .btn-login{
            width:100%;
            height:52px;
            border:none;
            border-radius:12px;
            background:#6366F1;
            color:#fff;
            font-weight:600;
            transition:.3s;
        }

        .btn-login:hover{
            background:#4F46E5;
        }

        .footer-text{
            text-align:center;
            color:#A3AED0;
            font-size:13px;
            margin-top:25px;
        }
    </style>
</head>

<body>

<div class="login-card">

    <div class="logo-box">
        S
    </div>

    <h2>Welcome Back</h2>

    <p class="subtitle">
        Student Management System
    </p>

    <% if(error){ %>
        <div class="alert alert-danger alert-dismissible fade show">
            <%= error %>
            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <form action="/login" method="POST">

        <div class="mb-3">
            <label class="form-label">
                Email Address
            </label>

            <input
                type="text"
                name="email"
                class="form-control"
                placeholder="Enter your email"
                required
            >
        </div>

        <div class="mb-4">
            <label class="form-label">
                Password
            </label>

            <input
                type="password"
                name="password"
                class="form-control"
                placeholder="Enter your password"
                required
            >
        </div>

        <button type="submit" class="btn btn-login">
            Sign In
        </button>

    </form>

    <div class="footer-text">
        © <%= new Date().getFullYear() %> Student Management System
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
